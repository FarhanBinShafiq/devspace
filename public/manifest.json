{
  "manifest_version": 3,
  "name": "DevSpace - Developer Toolkit",
  "version": "1.0.0",
  "description": "All-in-one developer toolkit: Code Snippets, Color Picker, Grid Overlay System & Responsive Device Checker.",
  "action": {
    "default_popup": "index.html"
  },
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "devspace@farhanbinshafiq.com",
      "strict_min_version": "109.0"
    }
  }
}
